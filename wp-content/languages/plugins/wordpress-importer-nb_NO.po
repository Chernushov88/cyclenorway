#: class-wp-import.php:316
msgid "To make it simpler for you to edit and save the imported content, you may want to reassign the author of the imported item to an existing user of this site, such as your primary administrator account."
msgstr "For å gjøre det enklere for deg å redigere og lagre det importerte innholdet ønsker du kanskje å tilordne forfatterskapet til det importerte elementet til en eksisterende bruker på dette nettstedet, som for eksempel din primære administratoren."

#: class-wp-import.php:1475
msgid "The uploaded file could not be moved"
msgstr "Den opplastede filen kunne ikke flyttes"

#: class-wp-import.php:1460
msgid "Sorry, this file type is not permitted for security reasons."
msgstr "Beklager, denne filtypen er ikke tillatt av sikkerhetsgrunner."

#: class-wp-import.php:1422
msgid "Downloaded file has incorrect size"
msgstr "Nedlastet fil har ugyldig størrelse"

#. translators: 1: The HTTP error message. 2: The HTTP error code.
#: class-wp-import.php:1398
msgid "Remote server returned the following unexpected result: %1$s (%2$s)"
msgstr "Fjern-serveren returnerte følgende uventede resultat: %1$s (%2$s)"

#. translators: 1: The WordPress error message. 2: The WordPress error code.
#: class-wp-import.php:1382
msgid "Request failed due to an error: %1$s (%2$s)"
msgstr "Forespørsel mislyktes på grunn av en feil: %1$s (%2$s)"

#: class-wp-import.php:1360
msgid "Could not create temporary file."
msgstr "Kunne ikke opprette midlertidig fil."

#: class-wp-import.php:154 class-wp-import.php:165 class-wp-import.php:239
#: class-wp-import.php:243 class-wp-import.php:254
msgid "Sorry, there has been an error."
msgstr "Beklager, en feil oppstod."

#. Author of the plugin
#: wordpress-importer.php
msgid "wordpressdotorg"
msgstr "wordpressdotorg"

#: class-wp-import.php:1678
msgid "Choose a WXR (.xml) file to upload, then click Upload file and import."
msgstr "Velg en WXR-fil (.xml) å laste opp, og klikk Last opp fil og importer."

#: class-wp-import.php:341
msgid "Submit"
msgstr "Send"

#. Author URI of the plugin
#: wordpress-importer.php
msgid "https://wordpress.org/"
msgstr "https://nb.wordpress.org/"

#: class-wp-import.php:244
msgid "The export file could not be found at <code>%s</code>. It is likely that this was caused by a permissions problem."
msgstr "Eksportfilen kunne ikke finnes på <code>%s</code>. Det er sannsynlig at dette skyldes et problem med rettigheter."

#: class-wp-import.php:385
msgid "or assign posts to an existing user:"
msgstr "eller tilordne innlegg til en eksisterende bruker:"

#: class-wp-import.php:453
msgid "Failed to create new user for %s. Their posts will be attributed to the current user."
msgstr "Mislyktes i å lage ny bruker for %s. Dennes innlegg vil bli til tilordnet inneværende bruker."

#: class-wp-import.php:370
msgid "or create new user with login name:"
msgstr "eller opprett en ny bruker med brukernavn:"

#: parsers/class-wxr-parser-simplexml.php:33
#: parsers/class-wxr-parser-simplexml.php:41 parsers/class-wxr-parser.php:68
msgid "There was an error when reading this WXR file"
msgstr "Det oppsto en feil ved lesing av denne WXR-filen"

#: class-wp-import.php:1662
msgid "A new version of this importer is available. Please update to version %s to ensure compatibility with newer export files."
msgstr "En ny versjon av dette importprogrammet er tilgjengelig. Vennligst oppdater til versjon %s for å sikre kompatibilitet med nyere eksportfiler."

#. Description of the plugin
#: wordpress-importer.php
msgid "Import posts, pages, comments, custom fields, categories, tags and more from a WordPress export file."
msgstr "Importer innlegg, sider, kommentarer, tilpassede felt, kategorier, stikkord og mer fra en eksportfil for WordPress.."

#: parsers/class-wxr-parser.php:69
msgid "Details are shown above. The importer will now try again with a different parser..."
msgstr "Detaljer er vist ovenfor. Importprogrammet vil nå prøve med en annen tolker..."

#: parsers/class-wxr-parser-regex.php:104
#: parsers/class-wxr-parser-simplexml.php:46
#: parsers/class-wxr-parser-simplexml.php:52
#: parsers/class-wxr-parser-xml-processor.php:190
#: parsers/class-wxr-parser-xml.php:106
msgid "This does not appear to be a WXR file, missing/invalid WXR version number"
msgstr "Dette ser ikke ut til å være en WXR-fil, mangler/ugyldig versjonsnummer for WXR"

#: class-wp-import.php:155
msgid "The file does not exist, please try again."
msgstr "Denne filen finnes ikke, vennligst prøv igjen."

#: class-wp-import.php:224
msgid "Remember to update the passwords and roles of imported users."
msgstr "Husk å oppdatere passordene og rollene til importerte brukere."

#: class-wp-import.php:1298
msgid "Fetching attachments is not enabled"
msgstr "Henting av vedlegg er ikke mulig"

#: class-wp-import.php:1231
msgid "Menu item skipped due to invalid menu slug: %s"
msgstr "Meny-element hoppet over på grunn av ugyldig fragment: %s"

#: class-wp-import.php:318
msgid "If a new user is created by WordPress, a new password will be randomly generated and the new user&#8217;s role will be set as %s. Manually changing the new user&#8217;s details will be necessary."
msgstr "Hvis en ny bruker er opprettet av WordPress vil et nytt passord bli generert tilfeldig og den nye brukerens rolle vil bli satt til %s. Det vil være nødvendig manuelt å endre den nye brukerens detaljer."

#: class-wp-import.php:262
msgid "This WXR file (version %s) may not be supported by this version of the importer. Please consider updating."
msgstr "Denne WXR-filen (versjon %s) støttes kanskje ikke av denne versjonen av importprogrammet. Vennligst vurder å oppgradere."

#: class-wp-import.php:373
msgid "as a new user:"
msgstr "som en ny bruker:"

#: class-wp-import.php:383
msgid "assign posts to an existing user:"
msgstr "tildel innlegg til en eksisterende bruker:"

#: class-wp-import.php:1224
msgid "Menu item skipped due to missing menu slug"
msgstr "Meny-element hoppet over på grunn av manglende fragment"

#: class-wp-import.php:595
msgid "Failed to import post tag %s"
msgstr "Mislyktes i å importere stikkord %s"

#: class-wp-import.php:522
msgid "Failed to import category %s"
msgstr "Mislyktes i å importere kategori %s"

#: class-wp-import.php:287
msgid "Failed to import author %s. Their posts will be attributed to the current user."
msgstr "Mislyktes i å importere forfatter %s. Dennes innlegg vil bli tilordnet inneværende bruker."

#: class-wp-import.php:1417
msgid "Zero size file downloaded"
msgstr "Lastet ned fil med null størrelse"

#: class-wp-import.php:1655
msgid "Import WordPress"
msgstr "Importer WordPress"

#: class-wp-import.php:1677
msgid "Howdy! Upload your WordPress eXtended RSS (WXR) file and we&#8217;ll import the posts, pages, comments, custom fields, categories, and tags into this site."
msgstr "Hei! Last opp din WordPress eXtended RSS-fil (WXR) og vi vil importere innlegg, sider, kommentarer, tilpassede felt, katgorier og stikkord til dette nettstedet."

#: class-wp-import.php:315
msgid "Assign Authors"
msgstr "Tildel forfattere"

